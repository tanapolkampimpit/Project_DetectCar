{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "python-api": {
        "ClusterId": "fastapi-cluster",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "fastapi-cluster": {
        "Destinations": {
          "node1": {
            "Address": "http://127.0.0.1:8000"
          }
        }
      }
    }
  }
}
